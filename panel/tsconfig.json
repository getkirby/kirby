{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"allowJs": true,
		"checkJs": false,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"jsx": "preserve",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"types": ["vite/client", "vitest"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"],
	"exclude": ["node_modules", "dist"]
}
